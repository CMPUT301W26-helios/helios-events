<resources>

    <style name="TextAppearance.Helios.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Helios.ScreenTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Helios.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Helios.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Helios.Body.Secondary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Helios.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Helios.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Helios.Label.Strong" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Helios.BottomNavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/helios_bottom_nav_label_size</item>
        <item name="android:lineHeight">@dimen/helios_bottom_nav_label_line_height</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="TextAppearance.Helios.Success" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorTertiary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Helios.CardView" parent="CardView">
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.Helios.MaterialCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">24dp</item>
    </style>

    <style name="Widget.Helios.Card.Surface" parent="Widget.Helios.MaterialCardView" />

    <style name="Widget.Helios.Card.ProfileSection" parent="Widget.Helios.MaterialCardView">
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <style name="Widget.Helios.Card.SecondaryContainer" parent="Widget.Helios.MaterialCardView">
        <item name="cardBackgroundColor">?attr/colorSecondaryContainer</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.Helios.Input" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/bg_helios_input</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textColorHint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.Helios.Input.SubtleHint" parent="Widget.Helios.Input">
        <item name="android:textColorHint">?attr/colorOutline</item>
    </style>

    <style name="Widget.Helios.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Helios.Button.Secondary" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Helios.Button.Danger" parent="Widget.Material3.Button">
        <item name="backgroundTint">?attr/colorErrorContainer</item>
        <item name="android:textColor">?attr/colorOnErrorContainer</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Helios.Button.Primary.Compact" parent="Widget.Helios.Button.Primary">
        <item name="android:minHeight">36dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingVertical">0dp</item>
    </style>

    <style name="Widget.Helios.Button.Secondary.Compact" parent="Widget.Helios.Button.Secondary">
        <item name="android:minHeight">36dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingVertical">0dp</item>
    </style>

    <style name="Widget.Helios.Button.Danger.Compact" parent="Widget.Helios.Button.Danger">
        <item name="android:minHeight">36dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingVertical">0dp</item>
    </style>


    <!-- Forces Material alert dialogs to use the theme colorSurface as background
         instead of the hard-coded white Material3 falls back to when
         colorSurfaceContainerHigh is not explicitly set in the theme. -->
    <style name="ThemeOverlay.Helios.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">?attr/colorSurface</item>
    </style>
</resources>
