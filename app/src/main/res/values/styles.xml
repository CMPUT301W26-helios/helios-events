<resources>

    <style name="Widget.Helios.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/helios_button_primary_tint</item>
        <item name="android:textColor">@color/helios_button_primary_text</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Helios.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/helios_button_secondary_tint</item>
        <item name="android:textColor">@color/helios_text_primary</item>
        <item name="strokeColor">@color/helios_button_secondary_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>