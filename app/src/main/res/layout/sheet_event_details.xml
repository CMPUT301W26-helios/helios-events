<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/group_7"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/helios_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">


        <View
            android:id="@+id/sheet_handle"
            android:layout_width="108dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"

            android:background="@drawable/handle" />

        <ImageView
            android:id="@+id/helios_brand_logo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Helios logo"
            android:src="@drawable/helios_logo_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_close"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="@color/helios_text_primary"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_event_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Name"
            android:textAlignment="center"
            android:textColor="@color/helios_text_primary"
            android:textSize="32sp" />

        <!-- NOTE: Placeholder poster image. Replace later with ImageAsset-loaded image -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/image_event_poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/elder_dance_poster_sample" />

        </com.google.android.material.card.MaterialCardView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="0dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_event_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@drawable/bg_helios_form_card"
                android:padding="8dp"
                android:text="Date"
                android:textColor="@color/helios_text_primary" />

            <TextView
                android:id="@+id/text_event_starting_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_helios_form_card"
                android:padding="8dp"
                android:text="Starts"
                android:textColor="@color/helios_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="6dp"
                android:text="→"
                android:textColor="@color/helios_text_primary"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/text_event_ending_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_helios_form_card"
                android:padding="8dp"
                android:text="Ends"
                android:textColor="@color/helios_text_primary" />

        </LinearLayout>


        <LinearLayout
            android:id="@+id/location_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_helios_form_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_location_pin"
                />

            <TextView
                android:id="@+id/text_event_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Location"
                android:textColor="@color/helios_text_primary" />

        </LinearLayout>


        <LinearLayout
            android:id="@+id/capacity_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_helios_form_card"
            android:orientation="vertical"
            android:padding="8dp">
            <TextView
                android:id="@+id/text_event_capacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="Waiting list: 0 / 0"
                android:textColor="@color/helios_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/description_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_helios_form_card"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/text_event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/helios_text_primary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_primary_action"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="48dp"
            android:text="Join Waiting List"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_comments_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Comments"
            android:textColor="@color/helios_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/comment_composer_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_helios_form_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/image_comment_composer_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/ic_avatar_placeholder"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_myplaces" />

            <EditText
                android:id="@+id/input_comment_body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Add a comment..."
                android:inputType="textMultiLine|textCapSentences"
                android:maxLength="500"
                android:maxLines="4"
                android:minHeight="36dp"
                android:textColor="@color/helios_text_primary"
                android:textColorHint="@color/helios_text_hint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_post_comment"
                style="@style/Widget.Helios.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minHeight="36dp"
                android:text="Post" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_replying_to"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/helios_text_hint"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_event_comments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
