<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="120dp"
    tools:context=".ui.nav.SetupEventFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <include
            android:id="@+id/include_event_setup_header"
            layout="@layout/include_submenu_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layout_create_event_form"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_container"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/include_event_setup_header">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Name:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_event_name"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Event name"
                android:inputType="textCapSentences" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Maximum # of Entrants (Optional):"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_max_entrants"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Optional"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Waitlist Limit (Optional):"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_waitlist_limit"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Optional"
                android:inputType="number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Venue Name:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_event_location_name"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Venue name"
                android:inputType="textCapWords" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Street Address:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_event_address"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Street address"
                android:inputType="textPostalAddress|textCapWords" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Event Description:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_event_description"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="6dp"
                android:gravity="top|start"
                android:hint="Brief description"
                android:inputType="textMultiLine" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Lottery Guidelines:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_lottery_guidelines"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="6dp"
                android:gravity="top|start"
                android:hint="Optional notes"
                android:inputType="textCapSentences|textMultiLine" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Interests/Tags (separate with commas):"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_event_tags"
                style="@style/Widget.Helios.Input.SubtleHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Tags"
                android:inputType="textCapWords" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Set Registration Date:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_registration_start"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_chip"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Start date"
                    android:textColor="?attr/colorOutline" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:gravity="center"
                    android:text="-"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_registration_end"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_chip"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="End date"
                    android:textColor="?attr/colorOutline" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Require Geolocation:"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_filter_chip"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_geo_on"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_left_active"
                    android:gravity="center"
                    android:text="On"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_geo_off"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_right_inactive"
                    android:gravity="center"
                    android:text="Off"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_geofence_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_helios_form_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Geofence Center and Radius"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_geofence_helper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Use your current location, or enter coordinates manually if needed."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_use_current_location"
                    style="@style/Widget.Helios.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Use Current Location" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_toggle_manual_coordinates"
                    style="@style/Widget.Helios.Button.Secondary.Compact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Show Manual Coordinates" />

                <LinearLayout
                    android:id="@+id/layout_manual_coordinates_fields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/edit_geofence_latitude"
                        style="@style/Widget.Helios.Input.SubtleHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Latitude"
                        android:inputType="numberDecimal|numberSigned" />

                    <EditText
                        android:id="@+id/edit_geofence_longitude"
                        style="@style/Widget.Helios.Input.SubtleHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Longitude"
                        android:inputType="numberDecimal|numberSigned" />
                </LinearLayout>

                <EditText
                    android:id="@+id/edit_geofence_radius"
                    style="@style/Widget.Helios.Input.SubtleHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Radius in meters"
                    android:inputType="number" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Private Event (hidden from listings):"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_filter_chip"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tv_private_on"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_left_inactive"
                    android:gravity="center"
                    android:text="Private"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_private_off"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toggle_right_active"
                    android:gravity="center"
                    android:text="Public"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Event Poster"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/helios_label_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_upload_image"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/bg_helios_input"
                    android:contentDescription="Selected event poster"
                    android:cropToPadding="true"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/placeholder_event" />

                <ProgressBar
                    android:id="@+id/progress_poster_upload"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap the poster to choose a PNG or JPG image."
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_create_event_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_create_event_form">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_cancel_back"
                style="@style/Widget.Helios.Button.Danger"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:minHeight="@dimen/helios_button_height"
                android:text="Cancel - Back" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_next_qr"
                style="@style/Widget.Helios.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="@dimen/helios_button_height"
                android:text="Next - QR Code" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
