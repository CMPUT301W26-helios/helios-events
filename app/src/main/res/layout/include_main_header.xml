<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivHeaderHeliosIcon"
        android:layout_width="@dimen/helios_header_icon_size"
        android:layout_height="@dimen/helios_header_icon_size"
        android:layout_marginEnd="@dimen/helios_header_icon_spacing"
        android:adjustViewBounds="true"
        android:contentDescription="Helios icon"
        android:scaleType="centerInside"
        android:src="@drawable/helios_logo_v1" />

    <TextView
        android:id="@+id/tvScreenTitle"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.Helios.ScreenTitle" />

</LinearLayout>
