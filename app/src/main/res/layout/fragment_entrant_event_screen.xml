<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/helios_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/helios_screen_padding"
        android:paddingTop="@dimen/helios_screen_top_padding"
        android:paddingEnd="@dimen/helios_screen_padding"
        android:paddingBottom="24dp">

        <include layout="@layout/include_helios_brand_header" />

        <TextView
            android:id="@+id/main_screen_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Welcome to Helios Events"
            android:textColor="@color/helios_text_primary"
            android:textStyle="bold"
            android:textSize="@dimen/helios_heading_size" />

        <TextView
            android:id="@+id/main_screen_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="(Subtitle Placeholder) NOTE THAT THIS WHOLE PAGE NEEDS TO BE REPLACED WITH A PROPER NAVIGATOR IMPLEMENTATION!"
            android:textColor="@color/helios_text_primary"
            android:textSize="@dimen/helios_subheading_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:background="@drawable/bg_helios_form_card"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available actions"
                android:textColor="@color/helios_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/helios_label_size" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Browse is always allowed. Event sign-up and organizer access require a completed profile. (Note that this is a demo of bg_helios_form_card)"
                android:textColor="@color/helios_text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_browse_events"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="@dimen/helios_button_width"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/helios_button_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Browse Events" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_try_sign_up"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="@dimen/helios_button_width"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/helios_button_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Try Event Sign-up" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_open_organizer"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="@dimen/helios_button_width"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/helios_button_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Open Organizer Menu" />

    </LinearLayout>
</ScrollView>