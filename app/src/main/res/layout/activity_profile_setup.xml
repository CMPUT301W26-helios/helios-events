<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/helios_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/helios_screen_padding"
        android:paddingTop="@dimen/helios_screen_top_padding"
        android:paddingEnd="@dimen/helios_screen_padding"
        android:paddingBottom="24dp">

        <include layout="@layout/include_helios_brand_header" />

        <TextView
            android:id="@+id/profile_setup_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Welcome New User!"
            android:textColor="@color/helios_text_primary"
            android:textStyle="bold"
            android:textSize="@dimen/helios_heading_size" />

        <TextView
            android:id="@+id/profile_setup_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Please Register Below:"
            android:textColor="@color/helios_text_primary"
            android:textSize="@dimen/helios_subheading_size" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:background="@drawable/bg_helios_form_card"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/helios_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/helios_label_size" />

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_helios_input"
                android:hint="John Doe"
                android:inputType="textPersonName"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:textColor="@color/helios_text_primary"
                android:textColorHint="@color/helios_text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Email"
                android:textColor="@color/helios_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/helios_label_size" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_helios_input"
                android:hint="JDoe@domain.com"
                android:inputType="textEmailAddress"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:textColor="@color/helios_text_primary"
                android:textColorHint="@color/helios_text_hint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Phone Number (Optional)"
                android:textColor="@color/helios_text_primary"
                android:textStyle="bold"
                android:textSize="@dimen/helios_label_size" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_helios_input"
                android:hint="XXX-XXX-XXXX"
                android:inputType="phone"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:textColor="@color/helios_text_primary"
                android:textColorHint="@color/helios_text_hint" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_sign_up"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="@dimen/helios_button_width"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/helios_button_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:enabled="false"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Sign up  >"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
