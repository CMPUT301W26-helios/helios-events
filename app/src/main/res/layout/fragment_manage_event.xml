<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/helios_background"
    tools:context=".ui.nav.ManageEventFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:id="@+id/iv_sun_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:contentDescription="Helios logo"
            android:src="@drawable/helios_logo_v1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_manage_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-black"
            android:text="Manage Event"
            android:textColor="@color/helios_text_primary"
            android:textSize="42sp"
            app:layout_constraintEnd_toStartOf="@id/iv_sun_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/card_event_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_container"
            android:orientation="vertical"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/tv_manage_event_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Name:"
                android:textColor="@color/helios_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_manage_event_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dance Class for Elders"
                android:textColor="@color/helios_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/button_view_event_page"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_helios_button_primary"
                android:textColor="#FFFFFF"
                android:text="View Event Page"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/button_view_qr_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_helios_button_primary"
                android:textColor="#FFFFFF"
                android:text="View QR Code"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/button_edit_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_helios_button_primary"
                android:textColor="#FFFFFF"
                android:text="Edit Event"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/button_show_mapped_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="48dp"
                android:background="@drawable/bg_helios_button_primary"
                android:textColor="#FFFFFF"
                android:text="Show Mapped Location of Entrants"
                android:textAllCaps="false" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

