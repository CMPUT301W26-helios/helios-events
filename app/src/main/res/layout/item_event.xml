<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/view_banner_bg"
            android:layout_width="0dp"
            android:layout_height="168dp"
            android:background="?attr/colorSecondaryContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_event_poster"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:paddingVertical="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_event"
            app:layout_constraintTop_toTopOf="@id/view_banner_bg"
            app:layout_constraintBottom_toBottomOf="@id/view_banner_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layout_event_badges_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_event_coorganizer_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_event_role_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/co_organizer_badge"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_event_private_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_event_role_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/private_event_badge"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Community Elder Dance Showcase"
            app:layout_constraintTop_toBottomOf="@id/view_banner_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_calendar_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_calendar"
            app:tint="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/tv_event_title"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_event_max_entrants"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_filter_chip"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            tools:text="40 seats"
            app:layout_constraintTop_toTopOf="@id/iv_calendar_icon"
            app:layout_constraintBottom_toBottomOf="@id/iv_calendar_icon"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_event_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Tue, Apr 8 | 6:00 PM"
            app:layout_constraintTop_toTopOf="@id/iv_calendar_icon"
            app:layout_constraintBottom_toBottomOf="@id/iv_calendar_icon"
            app:layout_constraintStart_toEndOf="@id/iv_calendar_icon"
            app:layout_constraintEnd_toStartOf="@id/tv_event_max_entrants" />

        <TextView
            android:id="@+id/tv_event_registration_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            tools:text="Registration closes at Apr 8, 2026 @ 00:00"
            app:layout_constraintTop_toBottomOf="@id/tv_event_date"
            app:layout_constraintStart_toStartOf="@id/tv_event_date"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/iv_location_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_location_pin"
            app:tint="?attr/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/tv_event_registration_status"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_event_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            tools:text="Main Hall, Helios Community Centre"
            app:layout_constraintTop_toTopOf="@id/iv_location_icon"
            app:layout_constraintStart_toEndOf="@id/iv_location_icon"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_event_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:maxLines="1"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="#dance  |  #community  |  #all-ages"
            app:layout_constraintTop_toBottomOf="@id/tv_event_location"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
