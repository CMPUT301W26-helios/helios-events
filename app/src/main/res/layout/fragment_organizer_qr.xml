<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ui.nav.OrganizerQrFragment">

    <!-- Header Section -->
    <include
        android:id="@+id/include_qr_header"
        layout="@layout/include_submenu_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/helios_screen_padding"
        android:layout_marginTop="@dimen/helios_screen_top_padding"
        android:layout_marginEnd="@dimen/helios_screen_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main QR Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_qr_box"
        style="@style/Widget.Helios.Card.SecondaryContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/helios_screen_padding"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="@dimen/helios_screen_padding"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/layout_mode_actions_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/include_qr_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_generated_qr_label"
                style="@style/TextAppearance.Helios.Label.Strong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Generated QR:"
                android:textColor="?attr/colorOnSecondaryContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- QR Image Container to maintain aspect ratio -->
            <FrameLayout
                android:id="@+id/layout_qr_image_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_helios_input"
                android:padding="12dp"
                app:layout_constraintBottom_toTopOf="@id/layout_qr_card_footer"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_generated_qr_label">

                <ImageView
                    android:id="@+id/image_qr_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_image"
                    tools:ignore="ContentDescription" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/layout_qr_card_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <!-- Preview button shown only in CREATE mode -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_preview_event_page"
                    style="@style/Widget.Helios.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preview Live Page"
                    android:visibility="gone" />

                <!-- Utility actions shown only after generation or in VIEW mode -->
                <LinearLayout
                    android:id="@+id/layout_qr_utility_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_copy_qr_value"
                        style="@style/Widget.Helios.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                    android:text="Copy" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_save_qr_image"
                        style="@style/Widget.Helios.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Save" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Actions Barrier -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/layout_mode_actions_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="layout_qr_bottom_actions,button_qr_back_view" />

    <!-- Action Bar for CREATE Mode -->
    <LinearLayout
        android:id="@+id/layout_qr_bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/helios_screen_padding"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_qr_cancel_back"
            style="@style/Widget.Helios.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_confirm_create_event"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Event" />
    </LinearLayout>

    <!-- Single Back Button for VIEW_EXISTING Mode -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_qr_back_view"
        style="@style/Widget.Helios.Button.Danger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/helios_screen_padding"
        android:text="Back to Manage Menu"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
