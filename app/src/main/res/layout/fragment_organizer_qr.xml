<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ui.nav.OrganizerQrFragment">

    <include
        android:id="@+id/include_qr_header"
        layout="@layout/include_submenu_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_qr_box"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/include_qr_header"
        app:layout_constraintBottom_toTopOf="@id/layout_qr_bottom_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_qr_card_inner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_container"
            android:padding="18dp">

            <TextView
                android:id="@+id/tv_generated_qr_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generated QR:"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="@dimen/helios_label_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/image_qr_preview"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:adjustViewBounds="true"
                android:background="?attr/colorSurface"
                android:scaleType="centerInside"
                android:src="@drawable/ic_image"
                app:layout_constraintBottom_toTopOf="@id/layout_qr_inline_actions"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_generated_qr_label"
                tools:ignore="ContentDescription" />

            <LinearLayout
                android:id="@+id/layout_qr_inline_actions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/image_qr_preview">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_preview_event_page"
                    style="@style/Widget.Helios.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/helios_button_height"
                    android:text="Preview Event Page" />

                <LinearLayout
                    android:id="@+id/layout_qr_utility_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_copy_qr_value"
                        style="@style/Widget.Helios.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:minHeight="@dimen/helios_button_height"
                        android:text="Copy Code" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_save_qr_image"
                        style="@style/Widget.Helios.Button.Secondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:minHeight="@dimen/helios_button_height"
                        android:text="Save Image" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- Red Back Button for viewing existing event QR codes -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_qr_back_view"
        style="@style/Widget.Helios.Button.Danger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:minHeight="@dimen/helios_button_height"
        android:text="Back to Manage Menu"
        android:visibility="gone"
        app:cornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <LinearLayout
        android:id="@+id/layout_qr_bottom_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_qr_cancel_back"
            style="@style/Widget.Helios.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:minHeight="@dimen/helios_button_height"
            android:text="Cancel - Back" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_confirm_create_event"
            style="@style/Widget.Helios.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:minHeight="@dimen/helios_button_height"
            android:text="Confirm - Create Event" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
