<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="44dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/bg_helios_form_card"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/image_comment_reply_avatar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/ic_avatar_placeholder"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_myplaces" />

        <TextView
            android:id="@+id/text_comment_reply_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Author"
            android:textColor="@color/helios_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_comment_reply_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_helios_form_card"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Organizer"
            android:textColor="@color/helios_text_hint"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_comment_reply_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="2h ago"
            android:textColor="@color/helios_text_hint"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/button_comment_reply_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Delete"
            android:textColor="@color/helios_text_hint"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_comment_reply_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Reply text"
        android:textColor="@color/helios_text_primary"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/action_comment_reply_like"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/image_comment_reply_like"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_heart_outline" />

        <TextView
            android:id="@+id/text_comment_reply_like_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0"
            android:textColor="@color/helios_text_hint"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
