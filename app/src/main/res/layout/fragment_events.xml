<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FAF6"
    android:paddingBottom="8dp">

    <!-- Header row: logo + title aligned -->
    <ImageView
        android:id="@+id/helios_brand_logo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:contentDescription="Helios logo"
        android:src="@android:drawable/ic_menu_today"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="sans-serif-black"
        android:text="Event List"
        android:textColor="#1A1C1E"
        android:textSize="32sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/helios_brand_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/helios_brand_logo"
        app:layout_constraintBottom_toBottomOf="@id/helios_brand_logo" />

    <!-- Search Bar Row -->
    <LinearLayout
        android:id="@+id/ll_search_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:paddingHorizontal="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:drawableEnd="@android:drawable/ic_menu_search"
            android:hint="Search for Event"
            android:paddingHorizontal="20dp"
            android:textColor="#1A1C1E"
            android:textColorHint="#44474E" />

        <ImageButton
            android:id="@+id/btn_filter"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_search_bar"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#1A1C1E" />
    </LinearLayout>

    <!-- Date Filters Visual State -->
    <LinearLayout
        android:id="@+id/ll_date_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/ll_search_row">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Between: "
            android:textColor="#44474E" />

        <TextView
            android:id="@+id/tv_filter_start_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_filter_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            tools:text="March 1, 2025" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="-" />

        <TextView
            android:id="@+id/tv_filter_end_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_filter_chip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            tools:text="Apr 1, 2025" />

        <ImageView
            android:id="@+id/btn_clear_date_filter"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#44474E" />
    </LinearLayout>

    <!-- Interest Chips Visual State -->
    <LinearLayout
        android:id="@+id/ll_interest_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/ll_date_filters">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interests: "
            android:textColor="#44474E" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_filter_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Event List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_events"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/ll_interest_filters"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_event" />

</androidx.constraintlayout.widget.ConstraintLayout>